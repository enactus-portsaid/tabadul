# ============================================================
# Tabadul — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# NEVER commit .env files with real secrets to version control.
# See /docs/environment-variables.md for full documentation.
# ============================================================

# ------------------------------------------------------------
# Supabase — Backend-as-a-Service
# ------------------------------------------------------------
# Get these from: https://supabase.com/dashboard → Project → Settings → API
# For local dev with `supabase start`, use the values printed in the terminal.

# Project URL (e.g., https://xxxxx.supabase.co or http://127.0.0.1:54321)
SUPABASE_URL=http://127.0.0.1:54321

# Public anonymous key (safe for client-side use)
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server-side ONLY — has full database access, bypasses RLS)
# Generate: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Mobile App (Expo) — Public Variables
# ------------------------------------------------------------
# Expo requires EXPO_PUBLIC_ prefix for client-accessible env vars.

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------
# Web App (Next.js) — Public Variables
# ------------------------------------------------------------
# Next.js requires NEXT_PUBLIC_ prefix for client-accessible env vars.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL (used for redirects, OAuth callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------

# Node environment: development | staging | production
NODE_ENV=development

# Web app port
PORT=3000

# Default locale (ar | en)
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# ------------------------------------------------------------
# Supabase Local Development (supabase start)
# ------------------------------------------------------------
# These are automatically set when running `supabase start`.
# Only needed if connecting to the local Supabase stack manually.

# Local PostgreSQL connection string
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Local Supabase Studio URL
# SUPABASE_STUDIO_URL=http://127.0.0.1:54323

# Local Supabase Inbucket (email testing) URL
# SUPABASE_INBUCKET_URL=http://127.0.0.1:54324

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
# Toggle features on/off during development.

# Enable AI matching engine (rule-based)
NEXT_PUBLIC_ENABLE_AI_MATCHING=false

# Enable chat moderation (Edge Function)
NEXT_PUBLIC_ENABLE_CHAT_MODERATION=false

# Enable push notifications
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false
